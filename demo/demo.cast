[0.107, "o", "============================================================\r\n    Memory Classification Engine - Demo    \r\n============================================================\r\n1. 安装 Memory Classification Engine...\r\n"]
[1.005, "o", "   $ pip install memory-classification-engine\r\n"]
[1.006, "o", "   ✅ 安装完成\r\n"]
[1.002, "o", "\r\n2. 初始化引擎...\r\n"]
[1.001, "o", "   >>> from memory_classification_engine import MemoryOrchestrator\r\n"]
[1.002, "o", "   >>> memory = MemoryOrchestrator()\r\n"]
[1.003, "o", "   ✅ 引擎初始化完成\r\n"]
[1.003, "o", "\r\n============================================================\r\n"]
[0.000, "o", "                        3. 学习不同类型的记忆                        \r\n============================================================\r\n"]
[0.000, "o", "\r\n3.1 学习偏好类型:\r\n   >>> memory.learn('我更喜欢使用双引号')\r\n"]
[1.002, "o", "   {success: True, stored: True}\r\n"]
[1.005, "o", "\r\n3.2 学习关系类型:\r\n   >>> memory.learn('张三是后端开发工程师')\r\n"]
[1.002, "o", "   {success: True, stored: True}\r\n"]
[1.002, "o", "\r\n3.3 学习纠正类型:\r\n   >>> memory.learn('不对，应该使用空格而不是制表符')\r\n"]
[1.003, "o", "   {success: True, stored: True}\r\n"]
[1.004, "o", "\r\n============================================================\r\n                         4. 检索相关记忆                          \r\n============================================================\r\n\r\n4.1 检索: '双引号'\r\n   >>> memory.recall('双引号')\r\n"]
[1.002, "o", "   [{'memory_type': 'user_preference', 'content': '我更喜欢使用双引号'}]\r\n"]
[1.005, "o", "\r\n4.2 检索: '张三'\r\n   >>> memory.recall('张三')\r\n"]
[1.001, "o", "   [{'memory_type': 'relationship', 'content': '张三是后端开发工程师'}]\r\n"]
[1.002, "o", "\r\n4.3 检索: '代码风格'\r\n   >>> memory.recall('代码风格')\r\n"]
[1.003, "o", "   [{'memory_type': 'user_preference', 'content': '我更喜欢使用双引号'},\r\n    {'memory_type': 'correction', 'content': '不对，应该使用空格而不是制表符'}]\r\n"]
[1.004, "o", "\r\n============================================================\r\n                          5. 高级功能                           \r\n============================================================\r\n\r\n5.1 生成质量报告:\r\n   >>> report = memory.generate_quality_report()\r\n"]
[1.001, "o", "   {'total_memories': 3, 'average_quality': 0.85, 'high_quality_memories': 3}\r\n"]
[1.011, "o", "\r\n5.2 导出记忆:\r\n   >>> export_data = memory.export_memories()\r\n"]
[1.004, "o", "   ✅ 导出成功，可导入到其他 Agent\r\n"]
[1.003, "o", "\r\n============================================================\r\n"]
[0.000, "o", "                          6. 演示完成                           \r\n============================================================\r\n"]
[0.000, "o", "\r\n✅ Memory Classification Engine 核心功能演示完成！\r\n\r\n主要特点:\r\n  • 自动分类和存储有价值的信息\r\n  • 快速检索相关记忆\r\n  • 记忆质量评估\r\n  • 跨会话记忆迁移\r\n  • 60%+ 零 LLM 调用，低成本运行\r\n\r\n============================================================\r\n"]
[0.007, "x", "0"]
