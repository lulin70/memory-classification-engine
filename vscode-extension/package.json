{
  "name": "memory-classification-engine",
  "displayName": "Memory Classification Engine",
  "description": "AI memory management extension for Cursor and VS Code",
  "version": "0.1.0",
  "publisher": "memory-classification-engine",
  "engines": {
    "vscode": "^1.60.0"
  },
  "categories": [
    "AI",
    "Other"
  ],
  "activationEvents": [
    "*"
  ],
  "main": "extension.js",
  "contributes": {
    "views": {
      "explorer": [
        {
          "id": "memoryClassificationEngine",
          "name": "MCE Memory",
          "icon": "resources/icon.svg"
        }
      ]
    },
    "commands": [
      {
        "command": "memoryClassificationEngine.recall",
        "title": "MCE: Recall Memories"
      },
      {
        "command": "memoryClassificationEngine.status",
        "title": "MCE: Memory Status"
      },
      {
        "command": "memoryClassificationEngine.forget",
        "title": "MCE: Forget Memory"
      },
      {
        "command": "memoryClassificationEngine.export",
        "title": "MCE: Export Memories"
      },
      {
        "command": "memoryClassificationEngine.import",
        "title": "MCE: Import Memories"
      }
    ],
    "menus": {
      "view/item/context": [
        {
          "command": "memoryClassificationEngine.forget",
          "when": "view == memoryClassificationEngine"
        }
      ]
    }
  },
  "scripts": {
    "lint": "eslint .",
    "pretest": "npm run lint",
    "test": "node ./test/runTest.js"
  },
  "devDependencies": {
    "@types/vscode": "^1.60.0",
    "@types/glob": "^7.1.3",
    "@types/mocha": "^8.0.4",
    "@types/node": "^14.14.37",
    "eslint": "^7.19.0",
    "glob": "^7.1.6",
    "mocha": "^8.2.1",
    "typescript": "^4.1.3",
    "vscode-test": "^1.5.0"
  },
  "dependencies": {
    "axios": "^0.21.1"
  }
}